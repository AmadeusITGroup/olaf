# General files to ignore
node_modules/
npm-debug.log
yarn-debug.log
yarn-error.log
.DS_Store
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE files
.idea/
.vscode/
*.swp
*.swo

# Conversation files
olaf-data-store/handover-conversation*.md

# Examples branch specific ignores
# Generated outputs from examples
examples/*/output/
examples/*/generated/
examples/*/temp/
examples/*/.cache/
examples/*/logs/

# Example-specific data stores
examples/*/olaf-data-store/findings/
examples/*/olaf-data-store/conversations/
examples/*/olaf-data-store/sessions/

# Documentation builds for examples
examples/*/docs/_build/
examples/*/docs/site/

# Example runtime files
examples/*/*.log
examples/*/*.tmp
examples/*/node_modules/
examples/*/__pycache__/

# Project Folders

